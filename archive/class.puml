@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

Person(player, "Player", "Plays the game")
System(game, "Online Game System", "Multiplayer game platform")
System_Ext(payment, "Payment Service", "Handles payments")

Rel(player, game, "Plays")
Rel(game, payment, "Processes payment")


top to bottom direction
skinparam linetype ortho

package Object{
    abstract class DrawableObject {
    # pos : glm::vec3
    # size : glm::vec3
    # rotateAngle : float
    # orderingLayer : int
    # isActive : bool = true

    + DrawableObject()
    + ~DrawableObject()

    + getTransform() : glm::mat4
    + GetIsActive() : bool
    + SetIsActive(isActive : bool) : void

    + Render(globalModelTransform : glm::mat4) : void
    + SetSize(sizeX : float, sizeY : float) : void
    + SetPosition(newPosition : glm::vec3) : void
    + SetRotation(degree : float) : void

    + SetOrderingLayer(layer : int) : void
    + Translate(moveDistance : glm::vec3) : void

    + getPos() : glm::vec3
    + getSize() : glm::vec3
    + getOrderingLayer() : int
    }
    class ImageObject {
    # texture : unsigned int
    # spriteRenderer : SpriteRenderer
    # sheetInfo : SpritesheetInfo
    # isAnimated : bool

    + ImageObject()
    + ~ImageObject()

    + GetSpriteRenderer() : SpriteRenderer
    + SetSpriteInfo(info : SpritesheetInfo) : void
    + SetTextureWithID(info : SpritesheetInfo, id : unsigned int) : void
    + SetTexture(path : string) : void
    + Render(globalModelTransform : glm::mat4) : void

    + SetIsAnimated(value : bool) : void
    + GetIsAnimated() : bool

    + OnColliderEnter(other : Collider) : void
    + OnColliderStay(other : Collider) : void
    + OnColliderExit(other : Collider) : void
    + OnTriggerEnter(other : Collider) : void
    + OnTriggerStay(other : Collider) : void
    + OnTriggerExit(other : Collider) : void
    }

    class EntityObject {
    # collider : Collider
    # animList : map<AnimationState, SpritesheetInfo>
    # currAnimState : AnimationState

    + EntityObject()
    + ~EntityObject()

    + SetSpriteInfo(info : SpritesheetInfo) : void
    + SetTexture(path : string) : void
    + Render(globalModelTransform : glm::mat4) : void

    + SetSize(sizeX : float, sizeY : float) : void
    + GetCollider() : Collider
    + setColliderSize(size : glm::vec3) : void

    + OnColliderEnter(other : Collider) : void
    + OnColliderStay(other : Collider) : void
    + OnColliderExit(other : Collider) : void
    + OnTriggerEnter(other : Collider) : void
    + OnTriggerStay(other : Collider) : void
    + OnTriggerExit(other : Collider) : void

    + SetAnimationSprite(state : AnimationState, spriteInfo : SpritesheetInfo) : void
    + ChangeAnimationState(anim : AnimationState) : void
    + UpdateCurrentAnimation() : void
    }

    class GizmosObject {
        - borderColor : glm::vec3

        + GizmosObject()
        + ~GizmosObject()

        + SetColor(r : float, g : float, b : float) : void
        + Render(globalModelTransform : glm::mat4) : void
    }

    class UiObject {
        - playerNumOwner : int

        + UiObject()
        + ~UiObject()

        + SetTexture(path : std::string) : void
        + Render(globalModelTransform : glm::mat4) : void

        + setNumOwner(Num : int) : void
        + getNumOwner() : int

        + OnColliderEnter(other : Collider*) : void
        + OnColliderStay(other : Collider*) : void
        + OnColliderExit(other : Collider*) : void
        + OnTriggerEnter(other : Collider*) : void
        + OnTriggerStay(other : Collider*) : void
        + OnTriggerExit(other : Collider*) : void
    }

    class TrapObject {
        + isActivate : bool = false

        - lifeTime : int
        - playerNumOwner : int
        - CanKnockback : bool
        - type : int
        - TileInRange : std::vector<TileObject*>

        + TrapObject()
        + ~TrapObject()

        + Render(globalModelTransform : glm::mat4) : void
        + SetTexture(path : std::string) : void

        + SetLifeTime(lifeTime : int) : void
        + ReduceLifeTime() : void
        + GetLifetime() : int

        + SetPlayerNumber(Num : int) : void
        + GetPlayerNumber() : int

        + SetCanKnockback(isCanKnockback : bool) : void
        + GetCanKnockback() : bool

        + SetType(type : int) : void
        + GetType() : bool

        + AddTileInRange(tile : TileObject*) : void
        + DeleteTileInRange(tile : TileObject*) : void
        + ExplodeTileInRange() : void

        + OnColliderEnter(other : Collider*) : void
        + OnColliderStay(other : Collider*) : void
        + OnColliderExit(other : Collider*) : void
        + OnTriggerEnter(other : Collider*) : void
        + OnTriggerStay(other : Collider*) : void
        + OnTriggerExit(other : Collider*) : void
    }

    enum TypeTrap {
        Trap
        Tnt
    }

    enum AnimationState {
    
    }
}

package InfoStruct{
    class OrthographicValue <<struct>> {
        + left : float 
        + right : float 
        + bottom : float 
        + top : float 
    }

    class SpritesheetInfo <<struct>> {
        + name : std::string = "name"
        + texture : std::string = "texture"
        + textureid : unsigned int = 0
        + spritewidth : float = 0
        + spriteheight : float = 0
        + sheetwidth : float = 0
        + sheetheight : float = 0
        + isLoop : bool = false
        + SpritesheetInfo()
        + SpritesheetInfo(...) : void
    }
}

package Collision{
    enum CollisionType {
        Static
        Kinematic
        Trigger
    }

    class Collider
    {
        - parent : ImageObject
        - previousPos : glm::vec3
        - collisionType : CollisionType
        - gizmos : GizmosObject
        - size : glm::vec3
        - halfSize : glm::vec3
        - isEnter : bool = false
        - isExit : bool = false

        + Collider(type : CollisionType, parent : ImageObject)
        + Update(size : glm::vec3, position : glm::vec3) : void
        + GetGizmos() : GizmosObject
        + GetSize() : glm::vec3
        + GetPreviousPos() : glm::vec3
        + GetParent() : ImageObject
        + SetPreviousPos(pos : glm::vec3) : void
        + GetHalfSize() : glm::vec3
        + SetGizmosColor(color : glm::vec3) : void
        + GetCollisionType() : CollisionType
        + SetCollisionType(type : CollisionType) : void
        + setColliderSize(size : glm::vec3) : void
    }
}



